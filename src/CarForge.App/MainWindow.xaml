<Window x:Class="CarForge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CarForge.App.Views"
        Title="CarForge" Height="760" Width="1120"
        Background="{StaticResource Bg}" Foreground="{StaticResource Text}"
        FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,8">
            <TextBlock Text="CarForge" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                       DockPanel.Dock="Left" Margin="0,0,16,0" />
            <Button Content="Escanear" Command="{Binding ScanCommand}" DockPanel.Dock="Right" Width="100" Margin="8,0,0,0" />
            <Button Content="Pack…" Command="{Binding BrowseCommand}" DockPanel.Dock="Right" Width="80" />
            <TextBox Text="{Binding PackPath, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" />
        </DockPanel>

        <DockPanel Grid.Row="1" LastChildFill="True" Margin="0,0,0,12">
            <TextBlock Text="Frota (opcional)" Foreground="{StaticResource TextDim}" VerticalAlignment="Center"
                       DockPanel.Dock="Left" Margin="0,0,12,0" />
            <Button Content="Frota…" Command="{Binding BrowseFleetCommand}" DockPanel.Dock="Right" Width="80" />
            <TextBox Text="{Binding FleetPath, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" />
        </DockPanel>

        <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,12">
            <Border Background="{StaticResource Surface}" CornerRadius="6" Padding="12" Margin="0,0,8,0">
                <StackPanel><TextBlock Text="Modelos" Foreground="{StaticResource TextDim}" />
                    <TextBlock Text="{Binding ModelCount}" FontSize="22" FontWeight="SemiBold" /></StackPanel></Border>
            <Border Background="{StaticResource Surface}" CornerRadius="6" Padding="12" Margin="0,0,8,0">
                <StackPanel><TextBlock Text="Duplicados" Foreground="{StaticResource TextDim}" />
                    <TextBlock Text="{Binding DupCount}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource Danger}" /></StackPanel></Border>
            <Border Background="{StaticResource Surface}" CornerRadius="6" Padding="12" Margin="0,0,8,0">
                <StackPanel><TextBlock Text="Colisões" Foreground="{StaticResource TextDim}" />
                    <TextBlock Text="{Binding CollisionCount}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource Warn}" /></StackPanel></Border>
            <Border Background="{StaticResource Surface}" CornerRadius="6" Padding="12">
                <StackPanel><TextBlock Text="Com tuning" Foreground="{StaticResource TextDim}" />
                    <TextBlock Text="{Binding TuningCount}" FontSize="22" FontWeight="SemiBold" /></StackPanel></Border>
        </UniformGrid>

        <TabControl Grid.Row="3" Background="Transparent" BorderThickness="0">
            <TabItem Header="Veículos">
                <views:VehiclesView DataContext="{Binding Vehicles}" Margin="0,12,0,0" />
            </TabItem>
            <TabItem Header="Faxina / dedup">
                <views:DedupView DataContext="{Binding Dedup}" Margin="0,12,0,0" />
            </TabItem>
            <TabItem Header="Split">
                <views:SplitView DataContext="{Binding Split}" Margin="0,12,0,0" />
            </TabItem>
            <TabItem Header="Handling">
                <views:HandlingView DataContext="{Binding Handling}" Margin="0,12,0,0" />
            </TabItem>
            <TabItem Header="Importar">
                <views:ImportView DataContext="{Binding Import}" Margin="0,12,0,0" />
            </TabItem>
            <TabItem Header="Validar">
                <views:ValidateView DataContext="{Binding Validate}" Margin="0,12,0,0" />
            </TabItem>
            <TabItem Header="Viewer 3D">
                <views:ViewerView Margin="0,12,0,0" />
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="4" Text="{Binding Status}" Foreground="{StaticResource TextDim}" Margin="0,12,0,0" />
    </Grid>
</Window>
