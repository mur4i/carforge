<Application x:Class="CarForge.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CarForge.App"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <local:DiffBrushConverter x:Key="DiffBrush" />
            <local:BoolToVisibilityConverter x:Key="BoolToVis" />

            <SolidColorBrush x:Key="Bg" Color="#1B1B1F" />
            <SolidColorBrush x:Key="Surface" Color="#26262B" />
            <SolidColorBrush x:Key="Border" Color="#3A3A40" />
            <SolidColorBrush x:Key="Text" Color="#ECECEC" />
            <SolidColorBrush x:Key="TextDim" Color="#9A9AA2" />
            <SolidColorBrush x:Key="Accent" Color="#378ADD" />
            <SolidColorBrush x:Key="Danger" Color="#E24B4A" />
            <SolidColorBrush x:Key="Warn" Color="#EF9F27" />

            <Style TargetType="Button">
                <Setter Property="Background" Value="{StaticResource Surface}" />
                <Setter Property="Foreground" Value="{StaticResource Text}" />
                <Setter Property="BorderBrush" Value="{StaticResource Border}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="12,6" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource Surface}" />
                <Setter Property="Foreground" Value="{StaticResource Text}" />
                <Setter Property="BorderBrush" Value="{StaticResource Border}" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="CaretBrush" Value="{StaticResource Text}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
