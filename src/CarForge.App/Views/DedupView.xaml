<UserControl x:Class="CarForge.App.Views.DedupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="clr-namespace:CarForge.App.Views"
             Foreground="{StaticResource Text}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource Surface}" CornerRadius="8" Padding="6" Margin="0,0,12,0">
            <ListBox ItemsSource="{Binding Groups}" SelectedItem="{Binding SelectedGroup}"
                     Background="Transparent" BorderThickness="0" Foreground="{StaticResource Text}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4">
                            <TextBlock Text="{Binding Model}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Badge}" Foreground="{StaticResource TextDim}" FontSize="11" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource Surface}" CornerRadius="8" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="{Binding SelectedGroup.Model}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock Text="{Binding SelectedGroup.Badge}" Foreground="{StaticResource TextDim}" Margin="0,0,0,12" />

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" ItemsSource="{Binding SelectedGroup.Occurrences}"
                              SelectedItem="{Binding OccurrenceA}" DisplayMemberPath="Display" />
                    <ComboBox Grid.Column="2" ItemsSource="{Binding SelectedGroup.Occurrences}"
                              SelectedItem="{Binding OccurrenceB}" DisplayMemberPath="Display" />
                </Grid>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <v:Viewer3DControl YftPath="{Binding OccurrenceA.YftAbsolute}" />
                        <TextBlock Text="{Binding OccurrenceA.PreviewLabel}" Foreground="{StaticResource TextDim}" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <v:Viewer3DControl YftPath="{Binding OccurrenceB.YftAbsolute}" />
                        <TextBlock Text="{Binding OccurrenceB.PreviewLabel}" Foreground="{StaticResource TextDim}" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>

                <ItemsControl ItemsSource="{Binding Diffs}" Margin="0,0,0,14">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="{StaticResource TextDim}" />
                                <TextBlock Grid.Column="1" Text="{Binding ValueA}" Foreground="{Binding IsDifferent, Converter={StaticResource DiffBrush}}" />
                                <TextBlock Grid.Column="2" Text="{Binding ValueB}" Foreground="{Binding IsDifferent, Converter={StaticResource DiffBrush}}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Renomear spawn (em todo lugar)" Command="{Binding RenameCommand}" Margin="0,0,8,0" />
                    <Button Content="Manter A, remover duplicados" Command="{Binding RemoveDuplicatesCommand}" />
                </StackPanel>
            </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
