<UserControl x:Class="CarForge.App.Views.VehiclesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="clr-namespace:CarForge.App.Views"
             Foreground="{StaticResource Text}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="430" />
        </Grid.ColumnDefinitions>

        <!-- LISTA -->
        <Border Grid.Column="0" Background="{StaticResource Surface}" CornerRadius="8" Padding="12" Margin="0,0,12,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- busca + contador -->
                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Margin="10,0,0,0"
                               Text="{Binding CountText}" Foreground="{StaticResource TextDim}" FontSize="12" />
                    <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"
                             ToolTip="Buscar por nome, handling, áudio ou classe" />
                </DockPanel>

                <!-- cabeçalho -->
                <Grid Grid.Row="1" Margin="6,0,16,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="14" /><ColumnDefinition Width="*" />
                        <ColumnDefinition Width="46" /><ColumnDefinition Width="128" />
                        <ColumnDefinition Width="104" /><ColumnDefinition Width="78" />
                        <ColumnDefinition Width="52" /><ColumnDefinition Width="84" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="modelo" Foreground="{StaticResource TextDim}" FontSize="11" />
                    <TextBlock Grid.Column="2" Text="ocorr" Foreground="{StaticResource TextDim}" FontSize="11" />
                    <TextBlock Grid.Column="3" Text="handling" Foreground="{StaticResource TextDim}" FontSize="11" />
                    <TextBlock Grid.Column="4" Text="áudio" Foreground="{StaticResource TextDim}" FontSize="11" />
                    <TextBlock Grid.Column="5" Text="classe" Foreground="{StaticResource TextDim}" FontSize="11" />
                    <TextBlock Grid.Column="6" Text="tuning" Foreground="{StaticResource TextDim}" FontSize="11" />
                    <TextBlock Grid.Column="7" Text=".yft" Foreground="{StaticResource TextDim}" FontSize="11" />
                </Grid>

                <ListBox Grid.Row="2" ItemsSource="{Binding Rows}" SelectedItem="{Binding SelectedRow}"
                         Background="Transparent" BorderThickness="0" Foreground="{StaticResource Text}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingStackPanel.IsVirtualizing="True"
                         VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14" /><ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="46" /><ColumnDefinition Width="128" />
                                    <ColumnDefinition Width="104" /><ColumnDefinition Width="78" />
                                    <ColumnDefinition Width="52" /><ColumnDefinition Width="84" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center"
                                        Background="{Binding Kind, Converter={StaticResource VerdictBrush}}" />
                                <TextBlock Grid.Column="1" Text="{Binding Model}" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" Margin="2,0,8,0" />
                                <TextBlock Grid.Column="2" Text="{Binding OccText}"
                                           Foreground="{Binding Kind, Converter={StaticResource VerdictBrush}}" />
                                <TextBlock Grid.Column="3" Text="{Binding HandlingText}" Foreground="{StaticResource TextDim}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="4" Text="{Binding AudioText}" Foreground="{StaticResource TextDim}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="5" Text="{Binding ClassText}" Foreground="{StaticResource TextDim}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="6" Text="{Binding TuningText}" Foreground="{StaticResource TextDim}" />
                                <TextBlock Grid.Column="7" Text="{Binding SizeText}" Foreground="{StaticResource TextDim}"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- PREVIEW DO SELECIONADO -->
        <Border Grid.Column="1" Background="{StaticResource Surface}" CornerRadius="8" Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="{Binding SelectedRow.Model}" FontSize="18" FontWeight="Bold" />
                    <TextBlock Text="{Binding SelectedRow.Tags}" Foreground="{StaticResource TextDim}" Margin="0,0,0,10" />

                    <v:Viewer3DControl YftPath="{Binding SelectedRow.YftAbsolute}" />

                    <Border Background="{StaticResource SurfaceAlt}" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                        <StackPanel>
                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="ocorrências" Foreground="{StaticResource TextDim}" /><TextBlock Grid.Column="1" Text="{Binding SelectedRow.OccText}" /></Grid>
                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="handling" Foreground="{StaticResource TextDim}" /><TextBlock Grid.Column="1" Text="{Binding SelectedRow.HandlingText}" /></Grid>
                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="áudio" Foreground="{StaticResource TextDim}" /><TextBlock Grid.Column="1" Text="{Binding SelectedRow.AudioText}" /></Grid>
                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="classe" Foreground="{StaticResource TextDim}" /><TextBlock Grid.Column="1" Text="{Binding SelectedRow.ClassText}" /></Grid>
                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="tuning" Foreground="{StaticResource TextDim}" /><TextBlock Grid.Column="1" Text="{Binding SelectedRow.TuningText}" /></Grid>
                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="tamanho .yft" Foreground="{StaticResource TextDim}" /><TextBlock Grid.Column="1" Text="{Binding SelectedRow.SizeText}" /></Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
