<Window x:Class="CarForge.App.Views.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Renomear spawn" Height="280" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource Bg}" Foreground="{StaticResource Text}"
        FontFamily="Segoe UI" FontSize="13">
    <StackPanel Margin="18">
        <TextBlock Text="Nome atual" Foreground="{StaticResource TextDim}" />
        <TextBlock x:Name="OldNameText" FontWeight="SemiBold" FontSize="15" Margin="0,2,0,12" />

        <TextBlock Text="Novo nome de spawn" Foreground="{StaticResource TextDim}" />
        <TextBox x:Name="NewNameBox" Margin="0,2,0,4" VerticalContentAlignment="Center" />
        <TextBlock Text="só minúsculas, números e _  (ex: as350pc_v2)" Foreground="{StaticResource TextDim}" FontSize="11" Margin="0,0,0,12" />

        <CheckBox x:Name="HandlingCheck" Content="Também renomear handlingId / handlingName" Foreground="{StaticResource Text}" Margin="0,0,0,6" />
        <CheckBox x:Name="ModKitCheck" Content="Também renomear id do modkit (tuning)" Foreground="{StaticResource Text}" Margin="0,0,0,16" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Width="90" Margin="0,0,8,0" IsCancel="True" />
            <Button Content="Renomear" Width="90" Click="OnOk" IsDefault="True" />
        </StackPanel>
    </StackPanel>
</Window>
